generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id               String  @id @default(cuid())
  clerkId          String  @unique
  stripeCustomerId String? @unique

  email           String? @unique
  firstName       String?
  lastName        String?
  imageUrl        String?
  isFirstTimeUser Boolean @default(true)

  resumes       Resume[]
  coverLetters  CoverLetter[]
  careerProfile CareerProfile?

  jobs            Job[]
  savedJobs       SavedJob[]
  jobDescriptions JobDescription[]

  interviews Interview[]
  feedback   Feedback[]

  generatedDocuments GeneratedDocument[]
  uploadedDocuments  UploadedDocument[]
  userSubscription   UserSubscription?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([clerkId])
}

model CareerProfile {
  id      String @id @default(cuid())
  userId  String @unique
  clerkId String @unique

  fullName String?
  email    String?
  phone    String?
  location String?
  website  String?
  linkedin String?
  gitHub   String?

  headline String?
  summary  String?

  skills          Json?
  techSkills      Json?
  workExperience  Json?
  education       Json?
  certifications  Json?
  projects        Json?
  accomplishments Json?

  federalDetails Json?

  rawSourceText  String?
  sourceResumeId String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([clerkId])
}

model Resume {
  id      String @id @default(cuid())
  userId  String
  clerkId String

  resumeType  ResumeType @default(CORPORATE)
  resumeTitle String?
  description String?

  parsed         Boolean @default(false)
  parsedWith     String?
  rawTextContent String?
  content        Json?

  shareToken String @unique @default(cuid())

  photoUrl    String?
  showPhoto   Boolean @default(true)
  themeColor  String  @default("#000000")
  themeId     String?
  borderStyle String  @default("squircle")

  firstName String?
  lastName  String?
  jobTitle  String?
  address   String?
  phone     String?
  email     String?
  userEmail String?
  userName  String?
  website   String?
  linkedin  String?
  gitHub    String?
  summary   String?

  skills   String[]
  interest String[]
  accomplishments Accomplishment[]
  jobDescriptionId String?
  jobDescriptionText String? @db.Text
  targetRole String?
  targetCompany String?
  uploadedFileUrl String?
  isUploaded      Boolean @default(false)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  techSkills     TechSkill[]
  workExperience WorkExperience[]
  education      Education[]
  certifications Certification[]
  projects       Project[]

  jobs               Job[]
  generatedDocuments GeneratedDocument[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([clerkId])
}

model WorkExperience {
  id       String @id @default(cuid())
  resumeId String

  position  String?
  company   String?
  startDate DateTime?
  endDate   DateTime?
  location  String?

  duties           String?
  responsibilities String?
  accomplishments  String?
  description      String?

  clearance       String?
  grade           String?
  status          String?
  time            String?
  hours           String?
  supervisor      String?
  supervisorPhone String?
  salary          String?

  resume Resume @relation(fields: [resumeId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([resumeId])
}

model TechSkill {
  id       String @id @default(cuid())
  resumeId String

  name   String?
  rating Int?

  resume Resume @relation(fields: [resumeId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([resumeId])
}

model Education {
  id       String @id @default(cuid())
  resumeId String

  degree      String?
  school      String?
  startDate   DateTime?
  endDate     DateTime?
  location    String?
  description String?

  resume Resume @relation(fields: [resumeId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([resumeId])
}

model Certification {
  id       String @id @default(cuid())
  resumeId String

  name          String?
  issuer        String?
  issuedDate    DateTime?
  expiresDate   DateTime?
  credentialUrl String?
  description   String?

  resume Resume @relation(fields: [resumeId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([resumeId])
}

model Project {
  id       String @id @default(cuid())
  resumeId String

  name         String?
  role         String?
  description  String?
  technologies String[]
  url          String?

  resume Resume @relation(fields: [resumeId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([resumeId])
}

model CoverLetter {
  id      String @id @default(cuid())
  userId  String
  clerkId String

  template    String?
  themeColor  String?
  themeId     String?
  borderStyle String  @default("squircle")
  showPhoto   Boolean @default(true)

  shareToken String @unique @default(cuid())

  body    String?
  content Json?

  firstName    String?
  lastName     String?
  userEmail    String?
  userPhone    String?
  userAddress  String?
  userPhotoUrl String?
  website      String?
  linkedin     String?
  gitHub       String?

  jobTitle       String?
  companyName    String?
  companyAddress String?
  companyPhone   String?
  companyEmail   String?
  recipientName  String?

  signatureUrl   String?
  signatureColor String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  generatedDocuments GeneratedDocument[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([clerkId])
}

model JobDescription {
  id      String @id @default(cuid())
  userId  String
  clerkId String

  title          String?
  company        String?
  location       String?
  employmentType String?
  salary         String?

  rawText    String
  parsedData Json?

  requiredSkills   String[]
  preferredSkills  String[]
  responsibilities String[]
  qualifications   String[]
  keywords         String[]

  source   JobDescriptionSource @default(PASTED)
  fileUrl  String?
  fileName String?

  user               User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  generatedDocuments GeneratedDocument[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([clerkId])
}

model GeneratedDocument {
  id      String @id @default(cuid())
  userId  String
  clerkId String

  jobDescriptionId String?
  resumeId         String?
  coverLetterId    String?

  type         GeneratedDocumentType
  resumeFormat ResumeType?

  title     String?
  content   Json?
  plainText String?

  aiModel         String?
  promptVersion   String?
  matchScore      Int?
  keywordMatches  String[]
  missingKeywords String[]

  user           User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  jobDescription JobDescription? @relation(fields: [jobDescriptionId], references: [id], onDelete: SetNull)
  resume         Resume?         @relation(fields: [resumeId], references: [id], onDelete: SetNull)
  coverLetter    CoverLetter?    @relation(fields: [coverLetterId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([clerkId])
  @@index([jobDescriptionId])
  @@index([resumeId])
  @@index([coverLetterId])
}

model UploadedDocument {
  id      String @id @default(cuid())
  userId  String
  clerkId String

  documentType UploadedDocumentType
  fileName     String?
  fileUrl      String?
  fileMimeType String?
  fileSize     Int?

  rawText     String?
  parsedData  Json?
  parser      String?
  parseStatus ParseStatus @default(PENDING)
  parseError  String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([clerkId])
  @@index([documentType])
}

model Job {
  id       String  @id @default(cuid())
  userId   String
  clerkId  String
  resumeId String?

  position    String
  company     String
  location    String?
  mode        Mode?
  status JobStatus @default(SAVED)
  salary      String?
  postedAt    DateTime?
  dateApplied DateTime?
  source String?
followUpDate DateTime?
notes String?
lastActivityAt DateTime?

  description  String?
  requirements String[]
  category     String?
  url          String?

  user     User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  resume   Resume?    @relation(fields: [resumeId], references: [id], onDelete: SetNull)
  savedJob SavedJob[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([clerkId])
  @@index([resumeId])
}

model SavedJob {
  id     String @id @default(cuid())
  userId String
  jobId  String

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  job  Job  @relation(fields: [jobId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([userId, jobId])
  @@index([userId])
  @@index([jobId])
}

model Interview {
  id     String @id @default(cuid())
  userId String

  role       String
  type       String
  level      String
  industry   String?
  techstack  String[]
  questions  String[]
  coverImage String?
  finalized  Boolean  @default(false)

  user     User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  feedback Feedback[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

model Feedback {
  id          String @id @default(cuid())
  userId      String
  clerkId     String
  interviewId String

  totalScore          Int
  categoryScores      Json
  strengths           String[]
  areasForImprovement String[]
  finalAssessment     String

  interview Interview @relation(fields: [interviewId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([interviewId])
  @@index([userId])
  @@index([clerkId])
}

model UserSubscription {
  id      String @id @default(cuid())
  userId  String @unique
  clerkId String @unique

  stripeCustomerId        String?   @unique
  stripeSubscriptionId    String?   @unique
  stripePriceId           String?
  stripeCurrentPeriodEnd  DateTime?
  stripeCancelAtPeriodEnd Boolean   @default(false)

  stripePlanName String?
  stripeInterval String?
  status         String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("user_subscriptions")
}

model BlogPost {
  id          String  @id @default(cuid())
  title       String
  description String
  imageUrl    String
  tag         String?
  content     String?
  slug        String? @unique

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum ResumeType {
  CORPORATE
  FEDERAL
  UPLOADED
  MANUAL
}

enum UploadedDocumentType {
  RESUME
  JOB_DESCRIPTION
  COVER_LETTER
  OTHER
}

enum JobDescriptionSource {
  PASTED
  UPLOADED
  URL
}

enum ParseStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

enum GeneratedDocumentType {
  CORPORATE_RESUME
  FEDERAL_RESUME
  COVER_LETTER
  RESUME_FEEDBACK
  INTERVIEW_PREP
}

enum Mode {
  FULLTIME
  PARTTIME
  INTERNSHIP
  CONTRACT
  APPRENTICESHIP
  SEASONAL
}
enum JobStatus {
  SAVED
  APPLICATION_STARTED
  APPLIED
  INTERVIEW_SCHEDULED
  INTERVIEW_COMPLETED
  OFFER_RECEIVED
  HIRED
  REJECTED
  WITHDRAWN
  
}
model Accomplishment {
  id             String   @id @default(cuid())
  title          String
  organization   String?
  date           DateTime?
  description    String?
  impact         String?

  resumeId       String
  resume         Resume   @relation(fields: [resumeId], references: [id], onDelete: Cascade)

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}